      ],
      "outputs": [
        "suspicious network check"
      ],
      "next_states": [
        "review_recommendation"
      ],
      "failure_paths": [
        "tool_timeout",
        "missing_required_input",
        "validation_failed"
      ],
      "human_approval_required": false
    },
    {
      "state_name": "review_recommendation",
      "trigger": "security checks complete",
      "responsible_agent": "PluginMarketplaceReviewAgent",
      "inputs": [
        "request",
        "context",
        "memory"
      ],
      "actions": [
        "draft approve reject recommendation"
      ],
      "tools_called": [
        "plugin_submission.review"
      ],
      "outputs": [
        "approve reject recommendation"
      ],
      "next_states": [
