  "tools": [
    {
      "tool_name": "audit_log.write",
      "description": "Append immutable audit event for decisions, tool calls, approvals, and denials.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PluginMarketplaceReviewAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "plugin_submission.review",
      "description": "Review third-party plugin submission.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PluginMarketplaceReviewAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "permission_scope.analyze",
      "description": "Run permission scope analysis for requested plugin permissions.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PluginMarketplaceReviewAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "suspicious_network.check",
      "description": "Check suspicious network request behavior.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PluginMarketplaceReviewAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "plugin_listing.approval_request",
      "description": "Request approval before plugin publish or listing.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "high",
      "requires_approval": true,
      "allowed_callers": [
        "CoordinatorAgent",
        "PluginMarketplaceReviewAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    }
  ],
  "workflows": [
    {
      "state_name": "intake",
      "trigger": "new request",
      "responsible_agent": "CoordinatorAgent",
      "inputs": [
        "request",
        "context",
        "memory"
      ],
      "actions": [
        "parse request",
        "detect domain",
        "select responsible agent"
      ],
      "tools_called": [
        "audit_log.write"
      ],
      "outputs": [
        "routing decision"
      ],
      "next_states": [
        "analyze"
      ],
