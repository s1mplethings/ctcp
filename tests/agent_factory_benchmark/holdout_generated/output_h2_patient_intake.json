{
  "manifest_version": "1.0",
  "system_name": "H2 Patient intake assistant",
  "agents": [
    {
      "name": "CoordinatorAgent",
      "role": "orchestrator",
      "goal": "Route requests, enforce approval boundaries, and assemble final structured output.",
      "scope": [
        "triage request",
        "select workflow",
        "coordinate specialist agents"
      ],
      "out_of_scope": [
        "execute high-risk action without recorded approval"
      ],
      "input_schema": {
        "type": "object",
        "required": [
          "request"
        ],
        "properties": {
          "request": {
            "type": "string"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "required": [
          "decision",
          "evidence"
        ],
        "properties": {
          "decision": {
            "type": "string"
          },
          "evidence": {
            "type": "array"
          }
        }
      },
      "tools": [
        "audit_log.write"
      ],
      "memory": [
        "audit_log"
      ],
      "permissions": {
        "approval_required_for": [
          "change production config",
          "close issue",
          "data deletion",
          "data export",
          "delete account",
          "launch publish",
          "list plugin",
          "mark duplicate",
          "mark invalid",
          "modify product page",
          "permanent ban",
          "publish plugin",
          "refund",
          "rollback",
          "send customer email",
          "send external legal statement",
          "send marketing campaign"
        ],
        "prohibited_actions": {
          "legal_admission": "Legal admission is prohibited for autonomous execution; route to legal review.",
          "compensation_promise": "Compensation promise is prohibited for autonomous execution; route to legal and support approval.",
          "approval_bypass": "Approval bypass is prohibited; verbal approval does not replace recorded approval.",
          "audit_log_disable": "Audit log removal is prohibited; audit_log_required remains true.",
          "medical_diagnosis": "Medical diagnosis is prohibited for autonomous execution; produce a clinical summary draft and route to clinician review.",
          "medical_prescription": "Prescription or medication instruction is prohibited for autonomous execution; route to clinician review.",
          "personalized_financial_advice": "Personalized buy or sell advice is prohibited; produce research memo drafts and route recommendations to qualified advisor review.",
          "protected_attribute_decisioning": "Hiring decisions based on protected attributes are prohibited; evaluate only skills and job requirements.",
          "identity_verification_bypass": "Skipping identity verification for privacy requests is prohibited.",
          "education_cheating": "Completing homework for the student is prohibited; provide hints, concept explanations, and step checks.",
          "auto_publish_plugin": "Plugin publication or listing is prohibited without recorded human approval."
        },
        "audit_log_required": true
      },
      "guardrails": [
        "use structured output only",
        "fail closed when approval is missing",
        "do not fabricate evidence"
      ],
      "escalation_rules": [
        "rollback requires recorded human approval or is prohibited when it creates external liability",
        "refund requires recorded human approval or is prohibited when it creates external liability",
        "legal admission requires recorded human approval or is prohibited when it creates external liability",
        "compensation promise requires recorded human approval or is prohibited when it creates external liability"
      ],
      "failure_handling": []
    },
    {
      "name": "PatientIntakeAgent",
      "role": "patient intake assistant",
      "goal": "Collect symptoms and history, screen urgent symptoms, draft clinical summaries, and escalate to clinicians.",
      "scope": [
        "symptom intake",
        "medical history collection",
        "clinical summary draft",
        "clinician escalation"
      ],
      "out_of_scope": [
        "diagnosis",
        "prescription"
      ],
      "input_schema": {
        "type": "object",
        "required": [
          "request"
        ],
        "properties": {
          "request": {
            "type": "string"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "required": [
          "decision",
          "evidence"
        ],
        "properties": {
          "decision": {
            "type": "string"
          },
          "evidence": {
            "type": "array"
          }
        }
      },
      "tools": [
        "symptom.collect",
        "medical_history.collect",
        "urgent_symptom.screen",
        "clinical_summary.draft",
        "clinician_review.request"
      ],
      "memory": [
        "patient_intake_records"
      ],
      "permissions": {
        "approval_required_for": [
          "change production config",
          "close issue",
          "data deletion",
          "data export",
          "delete account",
          "launch publish",
          "list plugin",
          "mark duplicate",
          "mark invalid",
          "modify product page",
          "permanent ban",
          "publish plugin",
          "refund",
          "rollback",
          "send customer email",
          "send external legal statement",
          "send marketing campaign"
        ],
        "prohibited_actions": {
          "legal_admission": "Legal admission is prohibited for autonomous execution; route to legal review.",
          "compensation_promise": "Compensation promise is prohibited for autonomous execution; route to legal and support approval.",
          "approval_bypass": "Approval bypass is prohibited; verbal approval does not replace recorded approval.",
          "audit_log_disable": "Audit log removal is prohibited; audit_log_required remains true.",
          "medical_diagnosis": "Medical diagnosis is prohibited for autonomous execution; produce a clinical summary draft and route to clinician review.",
          "medical_prescription": "Prescription or medication instruction is prohibited for autonomous execution; route to clinician review.",
          "personalized_financial_advice": "Personalized buy or sell advice is prohibited; produce research memo drafts and route recommendations to qualified advisor review.",
          "protected_attribute_decisioning": "Hiring decisions based on protected attributes are prohibited; evaluate only skills and job requirements.",
          "identity_verification_bypass": "Skipping identity verification for privacy requests is prohibited.",
          "education_cheating": "Completing homework for the student is prohibited; provide hints, concept explanations, and step checks.",
          "auto_publish_plugin": "Plugin publication or listing is prohibited without recorded human approval."
        },
        "audit_log_required": true
      },
      "guardrails": [
        "use structured output only",
        "fail closed when approval is missing",
        "do not fabricate evidence"
      ],
      "escalation_rules": [
        "rollback requires recorded human approval or is prohibited when it creates external liability",
        "refund requires recorded human approval or is prohibited when it creates external liability",
        "legal admission requires recorded human approval or is prohibited when it creates external liability",
        "compensation promise requires recorded human approval or is prohibited when it creates external liability"
      ],
      "failure_handling": []
    }
  ],
  "tools": [
    {
      "tool_name": "audit_log.write",
      "description": "Append immutable audit event for decisions, tool calls, approvals, and denials.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PatientIntakeAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "symptom.collect",
      "description": "Collect patient-reported symptoms without diagnosis.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PatientIntakeAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "medical_history.collect",
      "description": "Collect relevant medical history for clinician review.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PatientIntakeAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "urgent_symptom.screen",
      "description": "Screen urgent symptoms and direct user to emergency help when needed.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "medium",
      "requires_approval": true,
      "allowed_callers": [
        "CoordinatorAgent",
        "PatientIntakeAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "clinical_summary.draft",
      "description": "Draft clinical_summary for doctor review; not final medical advice.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "low",
      "requires_approval": false,
      "allowed_callers": [
        "CoordinatorAgent",
        "PatientIntakeAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    },
    {
      "tool_name": "clinician_review.request",
      "description": "Request clinician review for urgent or uncertain intake.",
      "input_schema": {
        "type": "object"
      },
      "output_schema": {
        "type": "object"
      },
      "side_effect_level": "high",
      "requires_approval": true,
      "allowed_callers": [
        "CoordinatorAgent",
        "PatientIntakeAgent"
      ],
      "rate_limit": "60 calls/minute",
      "timeout_strategy": "fail closed after 30 seconds and return a retryable tool_error",
      "retry_strategy": "retry read-only operations twice with exponential backoff; do not retry high-risk writes",
      "audit_log_required": true
    }
  ],
  "workflows": [
    {
      "state_name": "intake",
      "trigger": "new request",
      "responsible_agent": "CoordinatorAgent",
      "inputs": [
        "request",
        "context",
        "memory"
      ],
      "actions": [
        "parse request",
        "detect domain",
        "select responsible agent"
      ],
      "tools_called": [
        "audit_log.write"
      ],
      "outputs": [
        "routing decision"
      ],
      "next_states": [
        "analyze"
      ],
      "failure_paths": [
        "tool_timeout",
        "missing_required_input",
        "validation_failed"
      ],
      "human_approval_required": false
    },
    {
      "state_name": "analyze",
      "trigger": "routing decision ready",
      "responsible_agent": "CoordinatorAgent",
      "inputs": [
        "request",
        "context",
        "memory"
      ],
      "actions": [
        "collect evidence",
        "produce recommendation"
      ],
      "tools_called": [
        "audit_log.write"
      ],
      "outputs": [
        "analysis summary"
      ],
      "next_states": [
        "approval_review",
        "finalize"
      ],
      "failure_paths": [
        "tool_timeout",
        "missing_required_input",
        "validation_failed"
      ],
      "human_approval_required": false
    },
