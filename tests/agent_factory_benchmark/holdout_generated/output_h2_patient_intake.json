      ],
      "tools_called": [
        "audit_log.write"
      ],
      "outputs": [
        "agent manifest"
      ],
      "next_states": [],
      "failure_paths": [
        "tool_timeout",
        "missing_required_input",
        "validation_failed"
      ],
      "human_approval_required": false
    }
