{
  "schema_version": "ctcp-project-capability-bundles-v1",
  "families": {
    "narrative_gui_editor": {
      "required_bundles": [
        "editor_core",
        "scene_branching",
        "character_asset_management",
        "sample_content_generation",
        "preview_export",
        "delivery_ready"
      ],
      "bundles": {
        "editor_core": {
          "summary": "Project/sample loading plus editor workspace and action wiring.",
          "required_views": [
            "project_loader",
            "story_scene_branch_editor",
            "character_asset_manager",
            "preview_export_panel"
          ],
          "required_interactions": [
            "load_sample",
            "reset_sample",
            "save_state",
            "export_project"
          ],
          "required_file_suffixes": [
            "/editor/workspace.py",
            "/editor/actions.py",
            "/seed.py"
          ]
        },
        "scene_branching": {
          "summary": "Story/scene/choice graph editing and branching data model.",
          "required_views": [
            "story_scene_branch_editor"
          ],
          "required_interactions": [
            "add_scene",
            "update_scene",
            "update_branch"
          ],
          "required_file_suffixes": [
            "/story/scene_graph.py",
            "/sample_data/pipeline/chapter_plan.json",
            "/sample_data/pipeline/scene_graph.json",
            "/sample_data/pipeline/choice_map.json"
          ]
        },
        "character_asset_management": {
          "summary": "Character cards plus asset placeholder catalog management.",
          "required_views": [
            "character_asset_manager"
          ],
          "required_interactions": [
            "update_character",
            "bind_background"
          ],
          "required_file_suffixes": [
            "/cast/schema.py",
            "/assets/catalog.py",
            "/sample_data/pipeline/cast_cards.json",
            "/sample_data/pipeline/asset_placeholders.json"
          ]
        },
        "sample_content_generation": {
          "summary": "Staged narrative sample generation artifacts and provenance chain.",
          "required_views": [],
          "required_interactions": [],
          "required_file_suffixes": [
            "/sample_data/example_project.json",
            "/sample_data/source_map.json",
            "/sample_data/pipeline/theme_brief.json",
            "/sample_data/pipeline/chapter_plan.json"
          ]
        },
        "preview_export": {
          "summary": "Preview/export pipeline tied to current editor state.",
          "required_views": [
            "preview_export_panel"
          ],
          "required_interactions": [
            "export_project"
          ],
          "required_file_suffixes": [
            "/pipeline/prompt_pipeline.py",
            "/exporters/deliver.py",
            "/service.py"
          ]
        },
        "delivery_ready": {
          "summary": "Readable README, verify entry, manifest metadata, and user-facing project packaging contract.",
          "required_views": [],
          "required_interactions": [],
          "required_file_suffixes": [
            "/README.md",
            "/scripts/verify_repo.ps1",
            "/meta/manifest.json"
          ]
        }
      },
      "sample_generation_steps": [
        "theme_brief",
        "cast_cards",
        "chapter_plan",
        "scene_graph",
        "choice_map",
        "asset_placeholders",
        "source_map"
      ]
    },
