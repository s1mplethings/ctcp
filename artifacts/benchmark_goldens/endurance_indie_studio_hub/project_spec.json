{
  "schema_version": "ctcp-project-spec-v2",
  "goal_summary": "做一个给独立游戏团队用的本地生产协作平台",
  "target_user": "希望尽快验证想法的项目发起人",
  "problem_to_solve": "把模糊目标收束成一个最小可运行项目，而不是只停留在流程和证明工件上",
  "mvp_scope": [
    "提供可运行入口和 README 启动说明",
    "至少打通一条核心用户流程"
  ],
  "required_inputs": [
    "用户目标描述"
  ],
  "required_outputs": [
    "可运行项目代码",
    "README 启动说明",
    "至少一条核心流程的验证结果"
  ],
  "hard_constraints": [
    "respect explicit negative requirements from the user text"
  ],
  "assumptions": [
    "默认先生成最小可运行版本，再逐步扩展非核心能力",
    "默认交付形态采用最容易验证的闭环入口",
    "未指定部署环境时默认按本地可运行优先"
  ],
  "open_questions": [
    "非阻塞待确认: 尚未明确交付形态，先按最小闭环入口假设",
    "非阻塞待确认: 尚未明确运行环境，先按本地 smoke run 假设"
  ],
  "acceptance_criteria": [
    "README 能指导启动项目",
    "项目存在真实可运行入口",
    "至少一条核心用户流程通过 smoke run"
  ],
  "constraint_snapshot": {
    "系统规模": "适合5-20人小团队，轻量化设计，反对复杂企业级冗余功能",
    "本地部署": "保证数据安全和自主可控",
    "长期可用": "稳定性和易维护性"
  },
  "project_domain": "indie_studio_production_hub",
  "scaffold_family": "indie_studio_hub",
  "project_type": "indie_studio_hub",
  "project_archetype": "indie_studio_hub_web",
  "delivery_shape": "web_first",
  "build_profile": "high_quality_extended",
  "product_depth": "extended",
  "required_pages": 13,
  "required_screenshots": 10,
  "require_feature_matrix": true,
  "require_page_map": true,
  "require_data_model_summary": true,
  "require_search": true,
  "require_import_or_export": "both",
  "require_dashboard_or_project_overview": true,
  "core_modules": [
