{
  "schema_version": "ctcp-dispatch-config-v1",
  "mode": "manual_outbox",
  "public_delivery": {
    "mode": "e2e_virtual_delivery"
  },
  "role_providers": {
    "support_lead": "api_agent",
    "support_local_fallback": "ollama_agent",
    "patchmaker": "codex_agent",
    "fixer": "codex_agent"
  },
  "budgets": {
    "max_outbox_prompts": 20
  },
  "providers": {
    "codex_agent": {
      "enabled": false,
      "dry_run": true,
      "cmd": "codex",
      "model": "",
      "timeout_sec": 900,
      "fallback_to_manual_outbox": true
    },
    "ollama_agent": {
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key": "ollama",
      "model": "qwen2.5:7b-instruct",
      "auto_start": true,
      "start_timeout_sec": 20,
      "start_cmd": "ollama serve"
    }
  },
  "support_mode_router": {
    "enabled": true,
    "min_confidence": 0.62,
    "max_history": 8
  }
}
