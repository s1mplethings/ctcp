{
  "spec_id": "ctcp_context_pack_v1",
  "schema_version": "ctcp-context-pack-v1",
  "type": "object",
  "required": [
    "schema_version",
    "goal",
    "repo_slug",
    "summary",
    "files",
    "omitted"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ctcp-context-pack-v1"
    },
    "goal": {
      "type": "string"
    },
    "repo_slug": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "selection_strategy": {
      "type": "object",
      "additionalProperties": true
    },
    "knowledge_summary": {
      "type": "object",
      "required": [
        "purpose",
        "boundary",
        "api_usage_guidance",
        "selected_file_count",
        "omitted_file_count",
        "role_counts",
        "priority_paths"
      ],
      "properties": {
        "purpose": {
          "type": "string"
        },
        "boundary": {
          "type": "string",
          "const": "evidence_only_not_task_assignment"
        },
        "api_usage_guidance": {
          "type": "string"
        },
        "selected_file_count": {
          "type": "integer"
        },
        "omitted_file_count": {
          "type": "integer"
        },
        "role_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "priority_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "why",
          "content"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "role_hint": {
            "type": "string",
            "enum": [
              "contract",
              "planning",
              "implementation",
              "validation",
              "delivery",
              "product",
              "reference"
            ]
          },
          "relevance_summary": {
            "type": "string"
          },
          "compression_hint": {
            "type": "string"
          },
          "must_follow_rules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "avoid_patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "truncated": {
            "type": "boolean"
          }
        }
      }
    },
    "omitted": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "enum": [
              "too_large",
              "denied",
              "irrelevant",
              "invalid_request",
              "not_found",
              "budget_exceeded"
            ]
          }
        }
      }
    }
  }
}
